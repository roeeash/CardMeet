{
  "name": "cardmeet-backend",
  "version": "1.0.0",
  "description": "CardMeet backend API server",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "express": "^4.18.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.0.0",
    "pg": "^8.11.0",
    "knex": "^2.4.0",
    "bcryptjs": "^2.4.0",
    "jsonwebtoken": "^9.0.0",
    "socket.io": "^4.7.0",
    "redis": "^4.6.0",
    "cors": "^2.8.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.0",
    "winston": "^3.9.0",
    "express-rate-limit": "^6.8.0",
    "dotenv": "^16.3.0",
    "multer": "^1.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.4.0",
    "@types/pg": "^8.10.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/cors": "^2.8.0",
    "@types/multer": "^1.4.0",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.0",
    "eslint": "^8.44.0",
    "prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "keywords": [
    "node",
    "express",
    "typescript",
    "api",
    "cardmeet"
  ],
  "author": "",
  "license": "MIT"
